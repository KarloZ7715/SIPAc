@startuml 01-clases
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam classAttributeFontSize 10
skinparam packageFontSize 13
skinparam packageStyle rectangle
skinparam groupInheritance 2
skinparam nodesep 60
skinparam ranksep 40

title SIPAc — Diagrama de Clases\nModelo de Datos MongoDB con Mongoose ODM

' ─── LAYOUT: izquierda a derecha para mejor legibilidad ───
left to right direction

' ─── CLASES PRINCIPALES ──────────────────────────────

package "Gestión de Usuarios (M1)" as pkg_users #E8F5E9 {

  class User <<collection: users>> {
    - _id : ObjectId
    --
    - fullName : String
    - email : String {unique}
    - passwordHash : String {select:false}
    - role : «admin | docente»
    - isActive : Boolean
    - program? : String
    --
    .. Seguridad de login ..
    - failedLoginAttempts : Number
    - lockUntil? : Date
    .. Recuperación contraseña ..
    - passwordResetToken? : String {select:false}
    - passwordResetExpires? : Date {select:false}
    --
    - createdAt : Date
    - updatedAt : Date
    ==
    + isLocked() : Boolean
    + incrementLoginAttempts() : void
    + resetLoginAttempts() : void
  }

}

package "Carga de Documentos (M2/M3)" as pkg_files #E3F2FD {

  class UploadedFile <<collection: uploaded_files>> {
    - _id : ObjectId
    --
    - uploadedBy : ObjectId → User
    - originalFilename : String
    - gridfsFileId : ObjectId → GridFS
    - mimeType : «PDF | JPEG | PNG»
    - fileSizeBytes : Number {max: 20MB}
    - processingStatus : «pending | processing | completed | error»
    - processingError? : String
    - rawExtractedText? : String
    - ocrProvider? : «pdfjs_native | gemini_vision | mistral_ocr_3»
    - ocrConfidence? : Number [0..1]
    - isDeleted : Boolean
    - deletedAt? : Date
    --
    - createdAt : Date
    - updatedAt : Date
    ==
    + softDelete() : void
  }

}

package "Producción Académica (M4/M5A)" as pkg_products #FFF3E0 {

  class AcademicProduct <<collection: academic_products>> {
    - _id : ObjectId
    --
    - productType : «article | conference_paper | thesis | certificate | research_project»
    - owner : ObjectId → User
    - sourceFile : ObjectId → UploadedFile
    - isDeleted : Boolean
    - deletedAt? : Date
    --
    - createdAt : Date
    - updatedAt : Date
    ==
    + softDelete() : void
  }

  class ExtractedEntities <<embebida>> {
    - authors : String[]
    - title? : String
    - institution? : String
    - date? : Date
    - keywords : String[]
    - doi? : String
    - eventOrJournal? : String
    - extractionSource : «pdfjs_native | gemini_vision | mistral_ocr_3»
    - extractionConfidence : Number [0..1]
    - extractedAt : Date
  }

  class ManualMetadata <<embebida>> {
    - title? : String
    - authors : String[]
    - institution? : String
    - date? : Date
    - doi? : String
    - keywords : String[]
    - notes? : String
  }

}

package "Subtipos — Discriminator Pattern" as pkg_disc #FFF8E1 {

  class Article <<article>> {
    - journalName? : String
    - volume? : String
    - issue? : String
    - pages? : String
    - issn? : String
    - indexing : String[]
    - openAccess : Boolean
  }

  class ConferencePaper <<conference_paper>> {
    - eventName? : String
    - eventCity? : String
    - eventCountry? : String
    - eventDate? : Date
    - presentationType? : «oral | poster | workshop | keynote»
    - isbn? : String
  }

  class Thesis <<thesis>> {
    - thesisLevel? : «maestria | especializacion | doctorado»
    - director? : String
    - university? : String
    - faculty? : String
    - approvalDate? : Date
    - repositoryUrl? : String
  }

  class Certificate <<certificate>> {
    - issuingEntity? : String
    - certificateType? : «participacion | ponente | asistencia | instructor | otro»
    - relatedEvent? : String
    - issueDate? : Date
    - expirationDate? : Date
    - hours? : Number
  }

  class ResearchProject <<research_project>> {
    - projectCode? : String
    - fundingSource? : String
    - startDate? : Date
    - endDate? : Date
    - projectStatus? : «active | completed | suspended»
    - coResearchers : String[]
  }

}

package "Auditoría y Notificaciones (M7/M8)" as pkg_audit #F3E5F5 {

  class AuditLog <<collection: audit_logs>> {
    - _id : ObjectId
    --
    - userId : ObjectId → User
    - userName : String {desnormalizado}
    - action : «create | update | delete | login | login_failed»
    - resource : «academic_product | uploaded_file | user | session»
    - resourceId? : ObjectId
    - details? : String
    - ipAddress : String
    - userAgent? : String
    --
    - createdAt : Date
    __
    {Solo inserción — inmutable}
  }

  class Notification <<collection: notifications>> {
    - _id : ObjectId
    --
    - recipientId : ObjectId → User
    - type : «processing_complete | processing_error | system»
    - title : String
    - message : String
    - relatedResource? : RelatedResource
    - isRead : Boolean
    - emailSent : Boolean
    --
    - createdAt : Date
    __
    {TTL: 90 días}
  }

  class RelatedResource <<embebida>> {
    - kind : «uploaded_file | academic_product»
    - id : ObjectId
  }

  class ChatConversation <<collection: chat_conversations>> {
    - _id : ObjectId
    --
    - chatId : String
    - userId : ObjectId → User
    - title : String
    - messages : ChatMessage[]
    - isActive : Boolean
    - lastAccessedAt : Date
    --
    - createdAt : Date
    - updatedAt : Date
    __
    {Unique: (userId, chatId)}
    {TTL: 180 días (solo isActive=true)}
  }

  class ChatRateLimitBucket <<collection: chat_rate_limit_buckets>> {
    - _id : String
    --
    - scope : String
    - userId : String
    - windowStartedAt : Date
    - expiresAt : Date
    - count : Number
    __
    {TTL por expiresAt}
  }

}

' ─── RELACIONES ──────────────────────────────────────

' Composición (objetos embebidos)
AcademicProduct *-down- "1" ExtractedEntities
AcademicProduct *-down- "1" ManualMetadata
Notification *-down- "0..1" RelatedResource

' Herencia (discriminator pattern)
AcademicProduct <|-- Article
AcademicProduct <|-- ConferencePaper
AcademicProduct <|-- Thesis
AcademicProduct <|-- Certificate
AcademicProduct <|-- ResearchProject

' Referencias entre colecciones (con etiquetas descriptivas)
User "1" -right- "0..*" UploadedFile : Un usuario\ncarga muchos archivos >
User "1" -- "0..*" AcademicProduct : Un usuario es\ndueño de muchos productos >
User "1" -down- "0..*" AuditLog : Acciones\nregistradas >
User "1" -down- "0..*" Notification : Notificaciones\nrecibidas >
UploadedFile "1" -- "0..1" AcademicProduct : Archivo fuente\ndel producto >
User "1" -down- "0..*" ChatConversation : Conversaciones\ndel chat >
User "1" -down- "0..*" ChatRateLimitBucket : Buckets de\nrate limit chat >

note as N_DISC
  **Patrón Discriminator** de Mongoose:
  Una sola colección ""academic_products""
  con sub-esquemas por ""productType"".
  Los 5 subtipos heredan todos los
  atributos de la clase base.
end note
N_DISC .. pkg_disc

note as N_COLL
  Los nombres de colección mostrados
  son aliases lógicos de documentación.
  En runtime, Mongoose puede usar
  pluralización por defecto si no se
  define `collection` explícita.
end note
N_COLL .. pkg_audit

@enduml
