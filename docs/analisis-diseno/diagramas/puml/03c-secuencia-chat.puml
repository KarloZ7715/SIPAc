@startuml 03c-secuencia-chat
!theme plain
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 220

title SIPAc — Diagrama de Secuencia 3.4\nFlujo del Chat Inteligente Grounded (M9)

actor "Docente" as User
participant "Browser\n(Nuxt Client)\nuseChat hook" as Browser #LightBlue
participant "API Route\n/api/chat" as APIChat #LightGreen
participant "Model Selector\n(policy + candidates)" as Selector #MediumPurple
participant "LLM Candidate\n(streamText + tool calling)" as LLM #D8BFD8
participant "Search Tool\nsearchRepositoryProducts" as Tools #Orange
database "MongoDB\nacademic_products" as DB #Khaki
database "MongoDB\nchat_conversations" as DBChat #LightYellow
database "MongoDB\nchat_rate_limit_buckets" as DBRate #LightGray

== Inicio de Conversación ==

User -> Browser : Escribe pregunta en\nel chat (lenguaje natural)\nEj: "Búscame artículos\nde 2020 a 2025"
activate Browser

Browser -> APIChat : POST /api/chat\n{ id, messages[], selectedModel? }
activate APIChat

APIChat -> DBRate : enforceChatRateLimit(user)
activate DBRate
DBRate --> APIChat : bucket actualizado / 429
deactivate DBRate

APIChat -> APIChat : sanitizeChatMessages()\n(normaliza texto y filtra parts inválidas)

APIChat -> Selector : buildModelCandidates(selectedModel?)
activate Selector
Selector --> APIChat : [candidate1, candidate2, ...]
deactivate Selector

loop fallback automático por candidato
	APIChat -> LLM : streamText({ model: candidate,\n    tools: searchRepositoryProducts,\n    stopWhen: stepCountIs(3) })
	activate LLM

	LLM -> LLM : Analizar intención\ny decidir tool calls

	LLM -> Tools : tool call:\nsearchRepositoryProducts(filters)
	activate Tools

	Tools -> DB : Query híbrida grounded\n(estructurada + OCR/nativo)
	activate DB
	DB --> Tools : productos confirmados
	deactivate DB

	Tools --> LLM : contexto y evidencias
	deactivate Tools

	LLM --> APIChat : stream de respuesta / error
	deactivate LLM

	alt candidato exitoso
		APIChat -> APIChat : consumeSseStream() + createUIMessageStreamResponse()
		break
	else error no recuperable
		APIChat -> APIChat : intentar siguiente candidato
	end
end

APIChat -> DBChat : upsertConversation({ chatId, userId, title, messages, stoppedByUser? })
activate DBChat
DBChat --> APIChat : conversación actualizada
deactivate DBChat

APIChat --> Browser : ReadableStream (SSE)\ncon respuesta formateada\ny enlaces a documentos
deactivate APIChat

Browser -> Browser : useChat renderiza\nrespuesta en tiempo real

Browser --> User : Mostrar resultados:\n"Encontré 12 artículos...\n1. [Título] - Autores - 2024\n   [Ver documento] [Descargar]"

deactivate Browser

@enduml
