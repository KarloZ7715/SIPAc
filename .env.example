# ─── Base de Datos ───────────────────────────────────
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/sipac?retryWrites=true&w=majority&appName=<cluster>

# ─── Autenticación ──────────────────────────────────
JWT_SECRET=<cadena-aleatoria-minimo-32-caracteres>
ADMIN_EMAIL=<correo-admin-inicial>
ADMIN_PASSWORD=<contrasena-admin-inicial>

# ─── Google Gemini (Vercel AI SDK) ──────────────────
GOOGLE_API_KEY=<tu-api-key-de-google-ai-studio>
# Opcional: clave distinta para CI / E2E / Vitest (prioridad sobre GOOGLE_API_KEY si está definida)
GOOGLE_API_KEY_TEST=
# Por defecto NER/OCR solo usan Flash/Flash Lite; si es true, se usan también los modelos profesionales (solo pay as you go)
GOOGLE_GEMINI_INCLUDE_PRO_MODELS=false

# ─── NVIDIA NIM (NER estructurado, opcional; OpenAI-compatible) ──
NVIDIA_API_KEY=<tu-api-key-de-nvidia-nim>
# Base URL por defecto: https://integrate.api.nvidia.com/v1
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1

# ─── OpenRouter (NER estructurado, opcional) ───────
OPENROUTER_API_KEY=<tu-api-key-de-openrouter>
# URL pública de la app (OpenRouter recomienda HTTP-Referer)
OPENROUTER_APP_URL=<url-publica-de-sipac>

# ─── Groq (NER estructurado fallback, opcional) ────
GROQ_API_KEY=<tu-api-key-de-groq>

# ─── Cerebras (LLM estructurado) ──────────
CEREBRAS_API_KEY=<tu-api-key-de-cerebras>

# ─── Mistral OCR (opcional) ─────────────────────────
MISTRAL_API_KEY=

# ─── Selección de proveedor OCR ─────────────────────────
OCR_PROVIDER=gemini
# Cadena OCR Gemini (por defecto 3.1 Flash Lite primero: suele tener más RPD en plan free)
OCR_MAX_GEMINI_VISION_ATTEMPTS=6

# ─── Selección de proveedor LLM ─────────────────────
LLM_PROVIDER=gemini

# ─── Configuración del pipeline ──────────────────
NER_CONFIDENCE_THRESHOLD=0.7
# Segunda pasada de extracción común siempre (documentos academic; más coste API)
NER_ALWAYS_SECOND_PASS=true
# Desactivar fusión pasada1+pasada2 y volver a elegir solo la de mayor score
NER_MERGE_EXTRACTION_PASSES=false
# Segunda llamada LLM si el primer JSON de metadatos por tipo queda muy vacío
NER_PRODUCT_SPECIFIC_FILL_PASS=false
# Umbral de campos rellenos (0-1) por debajo del cual se intenta esa segunda llamada
NER_PRODUCT_SPECIFIC_SPARSE_THRESHOLD=0.4
RATE_LIMIT_DOCS_PER_HOUR=15
OCR_REQUEST_TIMEOUT_MS=45000
NER_REQUEST_TIMEOUT_MS=35000
# Cada clasificación/extracción/fallback cuenta como solicitud; con 2 pasadas NER el consumo RPD sube rápido
NER_MAX_CANDIDATE_ATTEMPTS=4

# ─── Compendios: varias obras por PDF (segmentación + NER por trozo) ──
# false por defecto: solo heurística local; true permite una llamada LLM barata acotada para límites de segmento
NER_SEGMENTATION_ENABLED=false
NER_SEGMENTATION_MAX_SEGMENTS=6
NER_SEGMENTATION_INPUT_MAX_CHARS=28000
NER_SEGMENTATION_MIN_SEGMENT_CHARS=400
NER_SEGMENTATION_MODEL_ID=gemini-2.5-flash-lite

# ─── Notificaciones por correo ───────────────
RESEND_API_KEY=<tu-api-key-de-resend>
RESEND_FROM_EMAIL=<correo-remitente-verificado-en-resend>

# ─── Sentry (errores y rendimiento) ──────────
SENTRY_DSN=https://...@o....ingest.us.sentry.io/...
SENTRY_ENV=production