# ─── Base de Datos ───────────────────────────────────
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/sipac?retryWrites=true&w=majority

# ─── Autenticación ──────────────────────────────────
JWT_SECRET=<cadena-aleatoria-minimo-32-caracteres>

# ─── Google Gemini (Vercel AI SDK) ──────────────────
GOOGLE_API_KEY=<tu-api-key-de-google-ai-studio>

# ─── Mistral OCR (opcional) ─────────────────────────
MISTRAL_API_KEY=<tu-api-key-de-mistral>
OCR_PROVIDER=gemini

# ─── Configuración del pipeline ────────
NER_CONFIDENCE_THRESHOLD=0.7
RATE_LIMIT_DOCS_PER_HOUR=15
