# Copia este archivo a `.env` para desarrollo local.
# No subas secretos reales al repositorio.
# En producción configura variables en tu plataforma de despliegue.
# Las variables `NUXT_PUBLIC_*` son visibles en cliente.

# --------------------------------------------------
# Requeridas (producción)
# --------------------------------------------------
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/sipac?retryWrites=true&w=majority&appName=<cluster> # Conexión principal a MongoDB.
JWT_SECRET=<secreto-aleatorio-min-32-caracteres> # Firma/verificación de JWT.
ADMIN_EMAIL=<correo-admin-inicial> # Correo del administrador semilla.
ADMIN_PASSWORD=<contrasena-admin-inicial> # Clave del administrador semilla.
GOOGLE_API_KEY=<api-key-google-ai-studio> # API key base para OCR/NER con Google.
NUXT_PUBLIC_APP_URL=https://tu-dominio.com # URL pública canónica de la app.

# --------------------------------------------------
# Banderas públicas (mantener en false en producción)
# --------------------------------------------------
NUXT_PUBLIC_ENABLE_TESTING_METRICS=false # Muestra métricas de testing en UI.
NUXT_PUBLIC_ENABLE_DEVTOOLS=false # Habilita devtools de Nuxt en cliente.

# --------------------------------------------------
# OAuth Google (opcionales; requeridas si habilitas login Google)
# --------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID= # Client ID de Google OAuth.
GOOGLE_OAUTH_CLIENT_SECRET= # Client secret de Google OAuth.
GOOGLE_OAUTH_REDIRECT_URI= # URL de callback registrada en Google.

# --------------------------------------------------
# Selección de proveedores
# --------------------------------------------------
OCR_PROVIDER=gemini # Proveedor OCR principal (gemini|mistral).
LLM_PROVIDER=gemini # Proveedor LLM principal del flujo NER/chat.

# --------------------------------------------------
# Claves opcionales (fallback/multi-proveedor)
# --------------------------------------------------
GOOGLE_API_KEY_TEST= # API key Google para test/CI (prioridad sobre GOOGLE_API_KEY).
GOOGLE_GEMINI_INCLUDE_PRO_MODELS=false # Incluye modelos Pro de Gemini (más costo e inusable en una key gratuita).
NVIDIA_API_KEY= # API key de NVIDIA NIM.
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1 # Endpoint base de NVIDIA NIM.
OPENROUTER_API_KEY= # API key de OpenRouter.
OPENROUTER_APP_URL= # URL pública usada como referencia en OpenRouter.
GROQ_API_KEY= # API key de Groq.
CEREBRAS_API_KEY= # API key de Cerebras.
MISTRAL_API_KEY= # API key de Mistral (OCR/fallback).

# --------------------------------------------------
# Ajuste OCR/NER
# --------------------------------------------------
RATE_LIMIT_DOCS_PER_HOUR=15 # Límite de documentos por usuario/hora.
OCR_REQUEST_TIMEOUT_MS=45000 # Timeout máximo OCR en milisegundos.
OCR_MAX_GEMINI_VISION_ATTEMPTS=6 # Reintentos máximos OCR con Gemini Vision.
NER_REQUEST_TIMEOUT_MS=35000 # Timeout máximo NER en milisegundos.
NER_MAX_CANDIDATE_ATTEMPTS=4 # Intentos máximos en cadena de candidatos NER.
NER_CONFIDENCE_THRESHOLD=0.7 # Umbral mínimo de confianza NER.
NER_ALWAYS_SECOND_PASS=true # Fuerza segunda pasada de extracción NER.
NER_MERGE_EXTRACTION_PASSES=false # Fusiona resultados de pasada 1 y 2.
NER_PRODUCT_SPECIFIC_FILL_PASS=false # Segunda pasada para completar campos vacíos por tipo.
NER_PRODUCT_SPECIFIC_SPARSE_THRESHOLD=0.4 # Umbral de vacíos para activar fill pass.

# Segmentación de compendios (múltiples obras por PDF)
NER_SEGMENTATION_ENABLED=false # Activa segmentación previa al NER.
NER_SEGMENTATION_MAX_SEGMENTS=6 # Máximo de segmentos por documento.
NER_SEGMENTATION_INPUT_MAX_CHARS=28000 # Máximo de caracteres de entrada a segmentar.
NER_SEGMENTATION_MIN_SEGMENT_CHARS=400 # Mínimo de caracteres por segmento.
NER_SEGMENTATION_MODEL_ID=gemini-2.5-flash-lite # Modelo usado para segmentación.

# --------------------------------------------------
# Correo (Brevo) - opcionales
# --------------------------------------------------
BREVO_API_KEY= # API key de Brevo para envío de correos.
BREVO_FROM_EMAIL= # Correo remitente verificado en Brevo.
BREVO_FROM_NAME=SIPAc # Nombre visible del remitente.

# --------------------------------------------------
# Observabilidad (Sentry) - opcionales
# --------------------------------------------------
SENTRY_DSN= # DSN del proyecto Sentry.
SENTRY_ENV=production # Entorno reportado a Sentry (production|staging|development).
