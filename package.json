{
  "name": "sipac",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "tunnel": "cloudflared tunnel --url http://localhost:3000",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "node -e \"const { execSync } = require('node:child_process'); try { execSync('pnpm exec nuxt typecheck', { stdio: 'inherit' }); console.log('PASS typecheck'); } catch (error) { console.log('FAIL typecheck'); process.exit(error.status ?? 1); }\"",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:eval:ner": "vitest run tests/evals/ner-field-evals.test.ts",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:e2e:ui": "playwright test --ui",
    "commitlint": "commitlint"
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript": "7.0.4",
      "tar": "7.5.11",
      "flatted": "3.4.2",
      "h3@^1.15.0": "1.15.6",
      "h3@>=2.0.0-0 <2.0.1-rc.15": "2.0.1-rc.15",
      "h3@2.0.1-rc.11": "2.0.1-rc.15",
      "@nuxt/test-utils>h3-next": "npm:h3@2.0.1-rc.15",
      "svgo": "4.0.1"
    }
  },
  "lint-staged": {
    "*.{ts,vue,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.33",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@ai-sdk/vue": "^3.0.116",
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@nuxt/ui": "^4.5.1",
    "@pinia/nuxt": "^0.11.3",
    "@sentry/nuxt": "10",
    "ai": "^6.0.104",
    "bcrypt": "^6.0.0",
    "file-type": "^21.3.1",
    "import-in-the-middle": "^3.0.0",
    "jose": "^6.1.3",
    "mongoose": "^9.2.3",
    "nuxt": "^4.3.1",
    "nuxt-security": "2.5.1",
    "pdfjs-dist": "^5.4.624",
    "resend": "^6.9.3",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@iconify-json/lucide": "^1.2.97",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@types/bcrypt": "^6.0.0",
    "@vitest/coverage-v8": "4.0.18",
    "@vue/test-utils": "^2.4.6",
    "cloudflared": "^0.7.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.1.1"
  }
}
