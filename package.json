{
  "name": "sipac",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "commitlint": "commitlint"
  },
  "lint-staged": {
    "*.{ts,vue,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.33",
    "@ai-sdk/vue": "^3.0.116",
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@nuxt/ui": "^4.5.1",
    "@pinia/nuxt": "^0.11.3",
    "ai": "^6.0.104",
    "bcrypt": "^6.0.0",
    "jose": "^6.1.3",
    "mongoose": "^9.2.3",
    "nuxt": "^4.3.1",
    "nuxt-security": "2.5.1",
    "pdfjs-dist": "^5.4.624",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@types/bcrypt": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
